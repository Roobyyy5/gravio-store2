# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/gravio_store?schema=public"

# -----------------------------------------------------------------------------
# CJ Dropshipping API (https://developers.cjdropshipping.com)
# -----------------------------------------------------------------------------
# Recommended: generate an API key in CJ dashboard -> API settings.
# Format: CJUserNum@api@xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CJ_API_KEY=""

# Legacy fallback - only used if CJ_API_KEY is not set.
CJ_EMAIL="your-cj-account@example.com"
CJ_PASSWORD="your-cj-api-password"

# Two-letter warehouse origin used when creating orders (createOrderV2.fromCountryCode).
CJ_FROM_COUNTRY_CODE="CN"

# -----------------------------------------------------------------------------
# NextAuth (admin authentication)
# -----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"

# Used once by `npm run db:seed` to create/update the admin login.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="orders@yourdomain.com"

# -----------------------------------------------------------------------------
# PayPal (payments)
# -----------------------------------------------------------------------------
# Get these from developer.paypal.com -> Apps & Credentials.
PAYPAL_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
PAYPAL_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# "sandbox" (default) or "live".
PAYPAL_ENV="sandbox"

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Used for absolute URLs in emails and PayPal redirect URLs.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
